{
  "compilerOptions": {
    // --- Language & Environment ---
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    // --- Paths ---
    "rootDir": "./src",
    "outDir": "./dist",

    // --- Module Resolution ---
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // --- Type Checking (strict = safe production code) ---
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    // --- Output ---
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,

    // --- Decorators (future-proofing) ---
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // --- Interop ---
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}